{
    "name": "kode/fibers",
    "description": "Kode/Fibers - 高性能 PHP Fiber 协程调度器。提供协程池、上下文传递、分布式调度、断路器、负载均衡、RPC 通信（JSON/gRPC/WebSocket）、分布式事务（2PC/TCC/Saga）、多框架集成等企业级特性。",
    "type": "library",
    "license": "Apache-2.0",
    "version": "3.4.0",
    "authors": [
        {
            "name": "Kode Team",
            "email": "382601296@qq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/psr7": "^2.8",
        "kode/context": "^2.1",
        "kode/aop": "^2.0",
        "kode/attributes": "^1.0",
        "kode/facade": "^2.0",
        "kode/http-client": "^2.1",
        "kode/console": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "suggest": {
        "ext-curl": "用于 HTTP 客户端 cURL 驱动",
        "ext-swoole": "用于 Swoole 协程支持",
        "ext-swow": "用于 Swow 协程支持"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Fibers\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Fibers\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/fibers"
    ],
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "test-coverage": "php vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    }
}
