{
    "name": "nova/fibers",
    "description": "A robust, framework-agnostic Fiber (纤程) client for PHP 8.1+, inspired by Swoole/Swow but built on native PHP Fibers with graceful fallbacks.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Byte Team - Nova PHP Lab",
            "email": "nova-team@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/console": "^5.0|^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Nova\\Fibers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nova\\Fibers\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "bin": [
        "bin/fibers"
    ]
},
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
