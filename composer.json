{
    "name": "kode/fibers",
    "description": "高性能 Fiber 线程池与协程调度器",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Byte Team",
            "email": "byte-team@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/psr7": "^2.8",
        "kode/aop": "^1.0",
        "kode/attributes": "^1.0",
        "kode/context": "^1.1",
        "kode/facade": "^1.2",
        "kode/http-client": "^2.1",
        "kode/console": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Fibers\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Fibers\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/fibers"
    ],
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "test-coverage": "php vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    }
}
