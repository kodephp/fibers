{
    "name": "nova/fibers",
    "description": "A robust, framework-agnostic Fiber (纤程) client for PHP 8.1+, inspired by Swoole/Swow but built on native PHP Fibers with graceful fallbacks.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Byte Team - Nova PHP Lab",
            "email": "nova-php@byte.team"
        }
    ],
    "require": {
        "php": "^8.1",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Nova\\Fibers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nova\\Fibers\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/fibers"
    ],
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
